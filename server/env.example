PORT=3001
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# NODE_ENV=production   # set this on Render/prod deployments
# HEALTH_TOKEN=your-random-secret   # protects /health from enumeration in prod
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens
CLIENT_ORIGIN=http://localhost:5174

# Cloudinary — https://cloudinary.com/console → Dashboard → API Keys
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override (default: llama-3.3-70b-versatile)
