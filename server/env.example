# =============================================================================
# PremiumTech Backend — Environment Variables
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Set NODE_ENV=production on Render / any prod deployment.

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Rotation: rotate via Neon Console → Connection → Reset password.
# After rotating: update this var on Render and trigger a redeploy.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens
# Rotation: replace both values → redeploy → all existing sessions will be invalidated.
# Rotate if: secret leaked, suspicious activity, or every 90 days in prod.

# ── Security ──────────────────────────────────────────────────────────────────
# Protects /health from enumeration in production.
# Generate with: openssl rand -hex 32
# HEALTH_TOKEN=your-random-token

# Comma-separated list of allowed frontend origins.
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console → Dashboard → API Keys
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
# Rotation: Cloudinary Console → API Keys → Generate new key → delete old one.
# Update this var on Render and redeploy.

# ── Cohere (embeddings) ───────────────────────────────────────────────────────
# Get from: https://dashboard.cohere.com/api-keys
# Model: embed-multilingual-v3.0 (1024 dims)
COHERE_API_KEY=your_cohere_api_key
# Rotation: Cohere Dashboard → API Keys → Create new key → revoke old one.

# ── Groq (LLM assistant) ──────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override
# Rotation: Groq Console → API Keys → Create new key → revoke old one.
