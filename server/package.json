{
  "name": "ecommerce-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "index:full": "bun src/scripts/index-products.ts --mode=full",
    "index:changed": "bun src/scripts/index-products.ts --mode=changed",
    "index:product": "bun src/scripts/index-products.ts --mode=product"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cohere-ai": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "zod": "^3.25.0"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
